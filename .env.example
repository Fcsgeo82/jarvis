# Jarvis .env — copie para .env e preencha os valores

# ── ElevenLabs TTS ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sua_chave_aqui
ELEVENLABS_VOICE_ID=seu_voice_id_aqui
# Opcional — padrões:
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=pcm_24000

# ── DeepSeek LLM (agente de voz — palma tripla) ────────────────────────────
# Obtenha sua chave gratuita em: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sua_chave_deepseek_aqui

# ── Antigravity IDE ─────────────────────────────────────────────────────────
# Sobrescreve o caminho padrão detectado automaticamente (opcional)
# ANTIGRAVITY_EXE=C:\Users\SEU_USUARIO\AppData\Local\Programs\Antigravity IDE\Antigravity IDE.exe

# ── Chrome URLs (opcional) ──────────────────────────────────────────────────
# CLAUDE_CODE_URL=https://claude.ai/new
# BINANCE_BTC_URL=https://www.binance.com/en/trade/BTC_USDT

# ── Whisper (STT offline) ──────────────────────────────────────────────────
# Modelos: tiny, base, small, medium, large-v3
# base = bom equilíbrio velocidade/precisão; small = mais preciso
# WHISPER_MODEL=base

# ── Configurações de Dispositivos de Áudio (Opcional) ───────────────────────
# Caso queira fixar dispositivos específicos ao invés da auto-detecção:
# Use IDs listados na inicialização do script (ex: 11)
# JARVIS_INPUT_DEVICE=
# JARVIS_OUTPUT_DEVICE=

